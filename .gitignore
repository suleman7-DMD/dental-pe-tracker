# Data files (too large for git — DB is shipped as .gz)
data/dental_pe_tracker.db
dental_pe_tracker.db
data/dental_pe_tracker_*.db
# DB backups (e.g. data/dental_pe_tracker.db.bak_audit_YYYYMMDD — 200MB+, never commit)
*.db.bak*
data/*.bak*
# Pre-phase / one-off DB snapshots (e.g. dental_pe_tracker.db.pre_phase4_bak — 230MB, never commit)
data/*_bak
data/*.db.pre_*
data/combined/
data/nppes/
data/gdn/
data/pesp/
data/pitchbook/processed/
data/data-axle/processed/
data/data-axle/debug-reports/

# Backups and logs
backups/
logs/*
!logs/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.env

